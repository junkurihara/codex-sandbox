#!/usr/bin/env sh
# Attach to the Codex control tmux session or a repository shell session.
set -eu

CONTAINER="${CX_CONTAINER:-codex}"
WORKDIR="${CX_WORKDIR:-/workspace}"
CONTROL_SESSION="${CX_SESSION:-${CX_CONTROL_SESSION:-codex-control}}"
REPO_SESSION_PREFIX="${CX_REPO_SESSION_PREFIX:-repo-}"
PROGRAM="$0"

usage() {
  cat <<EOF
Usage:
  $PROGRAM                 attach to or create the control session at $WORKDIR
  $PROGRAM <repo>          attach to or create a repo shell at $WORKDIR/<repo>
  $PROGRAM -l | ls | list  list sessions and available repos
  $PROGRAM -h | --help     show this help

Env:
  CX_CONTAINER           container name (default: codex)
  CX_WORKDIR             workspace root inside the container (default: /workspace)
  CX_CONTROL_SESSION     control session name (default: codex-control)
  CX_REPO_SESSION_PREFIX repo session prefix (default: repo-)
  CX_SESSION             legacy alias for CX_CONTROL_SESSION
EOF
}

tmux_has_session() {
  docker exec "$CONTAINER" tmux has-session -t "$1" >/dev/null 2>&1
}

session_status() {
  attached="$(docker exec "$CONTAINER" tmux display-message -p -t "$1" '#{session_attached}' 2>/dev/null || printf '0')"
  if [ "$attached" = "0" ]; then
    printf 'detached'
  elif [ "$attached" = "1" ]; then
    printf 'attached'
  else
    printf 'attached (%s clients)' "$attached"
  fi
}

session_cwd() {
  docker exec "$CONTAINER" tmux display-message -p -t "$1" '#{pane_current_path}' 2>/dev/null || printf '?'
}

print_session() {
  session="$1"
  printf '  %s: %s, cwd=%s\n' "$session" "$(session_status "$session")" "$(session_cwd "$session")"
}

list() {
  sessions="$(docker exec "$CONTAINER" tmux list-sessions -F '#S' 2>/dev/null || true)"

  echo "Control session:"
  if tmux_has_session "$CONTROL_SESSION"; then
    print_session "$CONTROL_SESSION"
  else
    echo "  (none)"
  fi

  echo
  echo "Repo sessions:"
  found_repo_session=0
  if [ -n "$sessions" ]; then
    for session in $sessions; do
      case "$session" in
        "$REPO_SESSION_PREFIX"*)
          print_session "$session"
          found_repo_session=1
          ;;
      esac
    done
  fi
  if [ "$found_repo_session" -eq 0 ]; then
    echo "  (none)"
  fi

  echo
  echo "Other sessions:"
  found_other_session=0
  if [ -n "$sessions" ]; then
    for session in $sessions; do
      case "$session" in
        "$CONTROL_SESSION" | "$REPO_SESSION_PREFIX"*) ;;
        *)
          print_session "$session"
          found_other_session=1
          ;;
      esac
    done
  fi
  if [ "$found_other_session" -eq 0 ]; then
    echo "  (none)"
  fi

  echo
  echo "Repos under $WORKDIR:"
  repos="$(docker exec "$CONTAINER" find "$WORKDIR" -maxdepth 1 -mindepth 1 -type d -printf '%f\n' 2>/dev/null || true)"
  if [ -n "$repos" ]; then
    printf '%s\n' "$repos" | sort | sed 's/^/  /'
  else
    echo "  (none)"
  fi
}

case "${1:-}" in
  -h | --help)
    usage
    exit 0
    ;;
esac

if ! docker ps --format '{{.Names}}' | grep -qx "$CONTAINER"; then
  echo "Container '$CONTAINER' is not running. Start it with: docker compose up -d" >&2
  exit 1
fi

case "${1:-}" in
  -l | ls | list)
    list
    exit 0
    ;;
esac

REPO="${1:-}"

if [ -z "$REPO" ]; then
  if ! docker exec "$CONTAINER" test -d "$WORKDIR"; then
    echo "Workspace root '$WORKDIR' not found in container '$CONTAINER'." >&2
    exit 1
  fi

  SESSION="$CONTROL_SESSION"
  CWD="$WORKDIR"
else
  case "$REPO" in
    /* | *"/"* | "." | "..")
      echo "Repo must be a single directory name under $WORKDIR." >&2
      exit 1
      ;;
  esac

  if ! docker exec "$CONTAINER" test -d "$WORKDIR/$REPO"; then
    echo "Repo '$REPO' not found under $WORKDIR in container '$CONTAINER'." >&2
    echo >&2
    list >&2
    exit 1
  fi

  SESSION="${REPO_SESSION_PREFIX}$(printf '%s' "$REPO" | tr '.:' '__')"
  CWD="$WORKDIR/$REPO"
fi

exec docker exec -it "$CONTAINER" tmux new-session -A -s "$SESSION" -c "$CWD"
